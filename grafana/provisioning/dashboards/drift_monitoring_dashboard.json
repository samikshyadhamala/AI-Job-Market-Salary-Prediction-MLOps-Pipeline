{
  "apiVersion": 1,
  "datasource": {"type": "mysql", "uid": "dfp911hdql2wwf"},
  "title": "AI Job Market — Drift Monitoring",
  "uid": "drift-monitoring-dashboard",
  "time": {"from": "now-7d", "to": "now"},
  "refresh": "30s",
  "tags": ["ml", "drift", "ai-jobs"],
  "style": "dark",
  "templating": {"list": []},
  "timepicker": {},
  "timezone": "",
  "panels": [
    {
      "id": 1,
      "title": "Data Quality Score",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "mysql", "uid": "dfp911hdql2wwf"},
      "targets": [
        {
          "rawSql": "SELECT run_timestamp as time, data_quality_score as value FROM monitoring.drift_metrics WHERE $__timeFilter(run_timestamp) ORDER BY run_timestamp DESC LIMIT 1",
          "refId": "A",
          "format": "time_series",
          "datasource": {"type": "mysql", "uid": "dfp911hdql2wwf"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "darkred", "value": null},
              {"color": "red", "value": 0.5},
              {"color": "yellow", "value": 0.7},
              {"color": "green", "value": 0.95}
            ]
          },
          "unit": "percentunit",
          "custom": {"displayMode": "gradient", "textMode": "value_and_name"}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "text": {"valueSize": 50, "titleSize": 14}
      }
    },
    {
      "id": 2,
      "title": "Feature Drift Share",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "mysql", "uid": "dfp911hdql2wwf"},
      "targets": [
        {
          "rawSql": "SELECT CONCAT(ROUND(feature_drift_share*100), '% Drifted') as key, 1 as value FROM monitoring.drift_metrics WHERE $__timeFilter(run_timestamp) ORDER BY run_timestamp DESC LIMIT 1",
          "refId": "A",
          "format": "table",
          "datasource": {"type": "mysql", "uid": "dfp911hdql2wwf"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "unit": "short"
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "key"}, "properties": [{"id": "displayName", "value": "Drifted"}]},
          {"matcher": {"id": "byName", "options": "value"}, "properties": [{"id": "unit", "value": "short"}]}
        ]
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "pieType": "donut",
        "displayLabels": [{"name": "name", "options": {} }]
      }
    },
    {
      "id": 3,
      "title": "Prediction Drift Score",
